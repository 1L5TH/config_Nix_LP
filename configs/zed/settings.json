{
  "agent": {
    "default_model": {
      "model": "claude-3-5-sonnet-latest",
      "provider": "zed.dev"
    }
  },
  "auto_install_extensions": {
    "basher": true,
    "log": true,
    "nix": true,
    "typst": true
  },
  "buffer_font_family": "Fira Code",
  "buffer_font_size": 16,
  "experimental.theme_overrides": {
    "background": "#000000b3",
    "background.appearance": "blurred",
    "editor.active_line.background": "#3f3f4600",
    "editor.background": "#282c3300",
    "editor.gutter.background": "#00000000",
    "panel.background": "#2f343e00",
    "status_bar.background": "#000000b3",
    "tab.active_background": "#00000055",
    "tab.inactive_background": "#2f343e00",
    "tab_bar.background": "#2f343e00",
    "terminal.background": "#00000000",
    "title_bar.background": "#000000b3",
    "title_bar.inactive_background": "#000000b3",
    "toolbar.background": "#282c3300"
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "languages": {
    "Markdown": {
      "format_on_save": "on"
    },
    "Nix": {
      "language_servers": [
        "nil",
        "!nixd"
      ]
    }
  },
  "lsp": {
    "nil": {
      "initialization_options": {
        "formatting": {
          "command": [
            "nixfmt"
          ]
        }
      }
    },
    "tinymist": {
      "initialization_options": {
        "exportPdf": "onSave",
        "formatterMode": "typstyle",
        "outputPath": "$root/$dir/$name"
      }
    }
  },
  "soft_wrap": "editor_width",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "theme": {
    "dark": "One Dark",
    "light": "One Light",
    "mode": "dark"
  },
  "ui_font_size": 16,
  "vim_mode": true
}
